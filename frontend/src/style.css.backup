/* JARVIS — Global Premium Styles */
:root {
  --bg-color: #050508;
  --accent-color: #0ea5e9;
  --accent-glow: rgba(14, 165, 233, 0.3);
  --glass-bg: rgba(10, 10, 15, 0.7);
  --glass-border: rgba(14, 165, 233, 0.15);
  --text-primary: #f8fafc;
  --text-secondary: rgba(148, 163, 184, 0.7);
  --font-main: 'Outfit', sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body {
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: var(--bg-color);
  font-family: var(--font-main);
  color: var(--text-primary);
}

/* Background gradient for depth */
body::before {
  content: "";
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: radial-gradient(circle at 50% 50%, rgba(14, 165, 233, 0.05) 0%, transparent 70%);
  pointer-events: none;
  z-index: -1;
}

#orb-canvas {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

#status-text {
  position: fixed;
  bottom: 48px;
  left: 50%;
  transform: translateX(-50%);
  color: var(--accent-color);
  font-size: 14px;
  letter-spacing: 3px;
  text-transform: lowercase;
  font-weight: 300;
  pointer-events: none;
  z-index: 10;
  opacity: 0.6;
  animation: pulse 2s infinite ease-in-out;
}

@keyframes pulse {
  0%, 100% { opacity: 0.4; transform: translateX(-50%) scale(1); }
  50% { opacity: 0.8; transform: translateX(-50%) scale(1.05); }
}

#jarvis-label {
  position: fixed;
  bottom: 20px;
  left: 50%;
  transform: translateX(-50%);
  color: rgba(14, 165, 233, 0.15);
  font-size: 11px;
  letter-spacing: 6px;
  text-transform: uppercase;
  font-weight: 400;
  pointer-events: none;
  z-index: 10;
}

#controls {
  position: fixed;
  top: 24px;
  right: 24px;
  display: flex;
  gap: 12px;
  z-index: 20;
}

#controls button {
  width: 42px;
  height: 42px;
  border: 1px solid var(--glass-border);
  border-radius: 12px;
  background: var(--glass-bg);
  color: var(--text-secondary);
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  backdrop-filter: blur(10px);
}

#controls button:hover {
  background: rgba(14, 165, 233, 0.1);
  color: var(--accent-color);
  border-color: var(--accent-color);
  box-shadow: 0 0 15px var(--accent-glow);
  transform: translateY(-2px);
}

#controls button.muted {
  color: #ef4444;
  border-color: rgba(239, 68, 68, 0.3);
}

#menu-dropdown {
  position: fixed;
  top: 76px;
  right: 24px;
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  border-radius: 16px;
  padding: 8px;
  z-index: 20;
  backdrop-filter: blur(16px);
  box-shadow: 0 10px 30px rgba(0,0,0,0.5);
  animation: slideIn 0.3s ease-out;
}

@keyframes slideIn {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}

#menu-dropdown button {
  display: block;
  width: 100%;
  padding: 10px 20px;
  border: none;
  background: none;
  color: var(--text-secondary);
  font-size: 13px;
  letter-spacing: 1px;
  text-align: left;
  cursor: pointer;
  border-radius: 10px;
  transition: all 0.2s;
  font-weight: 400;
}

#menu-dropdown button:hover {
  background: rgba(14, 165, 233, 0.1);
  color: var(--text-primary);
}

#error-log {
  position: fixed;
  bottom: 100px;
  left: 50%;
  transform: translateX(-50%);
  width: 90%;
  max-width: 650px;
  max-height: 180px;
  overflow-y: auto;
  background: rgba(10, 10, 15, 0.3);
  border: 1px solid rgba(14, 165, 233, 0.05);
  border-radius: 16px;
  padding: 12px;
  z-index: 15;
  backdrop-filter: blur(8px);
  display: flex;
  flex-direction: column;
  gap: 10px;
  scrollbar-width: none;
}

#error-log::-webkit-scrollbar { display: none; }

#error-log .log-entry {
  font-family: var(--font-mono);
  font-size: 11px;
  color: rgba(239, 68, 68, 0.7);
  border-left: 2px solid rgba(239, 68, 68, 0.2);
  padding: 4px 12px;
  background: rgba(239, 68, 68, 0.03);
  border-radius: 0 4px 4px 0;
}

#error-log .log-entry.frontend {
  color: var(--accent-color);
  border-left-color: rgba(14, 165, 233, 0.3);
  background: rgba(14, 165, 233, 0.03);
}

#captions {
  position: fixed;
  bottom: 150px;
  left: 50%;
  transform: translateX(-50%);
  width: 85%;
  max-width: 900px;
  text-align: center;
  color: #fff;
  font-size: 22px;
  font-weight: 300;
  text-shadow: 0 0 20px rgba(14, 165, 233, 0.6);
  z-index: 100;
  pointer-events: none;
  transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  opacity: 0;
  line-height: 1.5;
  filter: blur(5px);
}

#captions.visible {
  opacity: 1;
  filter: blur(0);
  transform: translateX(-50%) translateY(-10px);
}

/* Settings UI Overhaul */
.settings-backdrop {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(4px);
  z-index: 100;
  opacity: 0;
  transition: opacity 0.4s;
  pointer-events: none;
}

.settings-container.open .settings-backdrop {
  opacity: 1;
  pointer-events: auto;
}

.settings-panel {
  position: fixed;
  top: 0;
  right: -450px;
  width: 450px;
  height: 100%;
  background: rgba(10, 10, 15, 0.85);
  backdrop-filter: blur(25px);
  border-left: 1px solid var(--glass-border);
  z-index: 101;
  transition: right 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  padding: 40px;
  display: flex;
  flex-direction: column;
  box-shadow: -20px 0 50px rgba(0,0,0,0.5);
}

.settings-panel.open {
  right: 0;
}

.settings-header h2 {
  font-size: 28px;
  font-weight: 600;
  letter-spacing: -0.5px;
  margin-bottom: 30px;
  background: linear-gradient(to right, #fff, var(--accent-color));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

.settings-section {
  margin-bottom: 32px;
}

.settings-section h3 {
  font-size: 12px;
  text-transform: uppercase;
  letter-spacing: 2px;
  color: var(--text-secondary);
  margin-bottom: 16px;
  border-bottom: 1px solid var(--glass-border);
  padding-bottom: 8px;
}

.settings-field label {
  display: block;
  font-size: 13px;
  color: var(--text-secondary);
  margin-bottom: 8px;
}

.settings-input-row {
  display: flex;
  gap: 10px;
  align-items: center;
}

input[type="text"], input[type="password"], textarea, select {
  flex: 1;
  background: rgba(255,255,255,0.03);
  border: 1px solid var(--glass-border);
  border-radius: 10px;
  padding: 12px 16px;
  color: #fff;
  font-family: var(--font-main);
  font-size: 14px;
  transition: all 0.2s;
}

input:focus {
  outline: none;
  border-color: var(--accent-color);
  background: rgba(14, 165, 233, 0.05);
}

.settings-btn {
  background: var(--glass-bg);
  border: 1px solid var(--glass-border);
  color: var(--text-primary);
  padding: 10px 20px;
  border-radius: 10px;
  cursor: pointer;
  font-size: 13px;
  font-weight: 500;
  transition: all 0.2s;
}

.settings-btn.primary {
  background: var(--accent-color);
  border-color: var(--accent-color);
  color: #fff;
}

.settings-btn:hover {
  transform: translateY(-1px);
  filter: brightness(1.1);
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #444;
}

.status-dot.status-green { background: #10b981; box-shadow: 0 0 8px #10b981; }
.status-dot.status-red { background: #ef4444; box-shadow: 0 0 8px #ef4444; }
.status-dot.status-yellow { background: #f59e0b; box-shadow: 0 0 8px #f59e0b; }

.status-grid {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.status-row {
  display: flex;
  align-items: center;
  gap: 12px;
  font-size: 14px;
}
